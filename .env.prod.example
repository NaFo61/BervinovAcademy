# Шаблон для сервера: cp .env.prod.example .env и заполни секреты

DEBUG=False
DJANGO_LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-long-random-string
SUB_PATH=/academy

DB_ENGINE=django.db.backends.postgresql
DB_NAME=bervinov_academy
DB_USER=bervinov
DB_PASSWORD=change-me-strong-db-password
DB_HOST=db
DB_PORT=5432

ALLOWED_HOSTS=161.104.46.236,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://161.104.46.236,http://161.104.46.236,http://localhost
CORS_ALLOWED_ORIGINS=https://161.104.46.236,http://161.104.46.236,http://localhost
USE_X_FORWARDED_HOST=True
FRONTEND_URL=https://161.104.46.236/academy

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CHANNEL_LAYERS_REDIS=redis://redis:6379/1

KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=code-submissions
KAFKA_TOPIC_CODE_RESULTS=code-submission-results
KAFKA_GROUP_CODE_RESULTS=django-code-submission-results
