# Debug
DEBUG=True

# Уровень логов Django: DEBUG, INFO, WARNING, ERROR
DJANGO_LOG_LEVEL=INFO

# Secret Key - СГЕНЕРИРУЙ НОВЫЙ ДЛЯ ПРОДАКШЕНА!
SECRET_KEY=your-super-secret-key-here-change-in-production

# Database PostgreSQL
DB_ENGINE=django.db.backends.postgresql
DB_NAME=your_database_name_here
DB_USER=your_database_user_here
DB_PASSWORD=your-strong-database-password-here
DB_HOST=localhost
DB_PORT=5432

# Django Security
# Для доступа с другого устройства в Wi‑Fi добавьте IPv4 ПК: ipconfig → Wi‑Fi
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost,192.168.1.196
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://192.168.1.196,http://localhost,http://127.0.0.1

# Frontend
FRONTEND_URL=http://localhost:3000

# Kafka (kafka-python; new CodeSubmission is published to this topic)
# Django on host: localhost:9092. Backend in docker-compose: kafka:29092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=code-submissions
# Результаты проверки: воркер code-check-runner пишет сюда;
# ``python manage.py consume_code_submission_results``
# (сервис kafka-results-consumer в docker-compose) читает и обновляет CodeSubmission.
KAFKA_TOPIC_CODE_RESULTS=code-submission-results
# Отдельная consumer group для Django (не совпадать с group воркера проверки).
KAFKA_GROUP_CODE_RESULTS=django-code-submission-results
KAFKA_RESULTS_AUTO_OFFSET_RESET=earliest
# LiveKit Cloud (видеоконференции). Без ключей API join вернёт 503.
# Build (бесплатно): https://cloud.livekit.io → Project → Settings → Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL_HOURS=4
CONFERENCE_WAITING_TTL_HOURS=24
CONFERENCE_MENTOR_ABSENCE_MINUTES=5

# Воркер code-check-runner (services/code_check_emulator) читает тот же входной топик,
# что и KAFKA_TOPIC выше; проверка — только через docker run образа песочницы,
# нужен доступ к docker.sock (Linux / Docker Desktop).
